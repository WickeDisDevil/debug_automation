# ── GPT-oss-20B (local, OpenAI-compatible server) ────────────────────────────
# Defaults assume Ollama running locally with `ollama pull gpt-oss:20b`
GPT_OSS_BASE_URL=http://localhost:11434/v1
GPT_OSS_API_KEY=ollama
GPT_OSS_MODEL=gpt-oss:20b
GPT_OSS_TIMEOUT_SECONDS=120
GPT_OSS_MAX_RETRIES=3

# ── Embedding model (sentence-transformers, runs in-process) ─────────────────
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384
EMBEDDING_DEVICE=cpu

# ── Qdrant (self-hosted) ─────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=bugfix_embeddings
QDRANT_API_KEY=

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql+asyncpg://bugfix:bugfix@localhost:5432/bugfix_ai

# ── GitHub Code Scanning ─────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_replace_me
GITHUB_OWNER=AMD-SWV-Driver
GITHUB_REPO=drivers
GITHUB_REF=amd/release/25.30.01.67-SWV
GITHUB_SEVERITY_FILTER=critical,high,medium,low
GITHUB_TOOL_FILTER=CodeQL
GITHUB_POLL_INTERVAL_SECONDS=900

# ── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=bugfix-ai-production

# ── LangSmith (optional) ─────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=bugfix-ai

# ── App ──────────────────────────────────────────────────────────────────────
API_KEY=dev-replace-me
ENVIRONMENT=development
CHECKPOINTER_TYPE=postgres
SQLITE_DB_PATH=./checkpoints.db

# ── Log sources ──────────────────────────────────────────────────────────────
LOG_SOURCE=file
LOG_BASE_PATH=/var/log/services

# ── Safety ───────────────────────────────────────────────────────────────────
TERMINAL_DRY_RUN_DEFAULT=true
TERMINAL_ALLOWLIST_PATH=./config/terminal_allowlist.yaml
